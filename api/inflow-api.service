[Unit]
Description=INFLOW API
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/inflow
ExecStart=/home/ubuntu/.local/bin/uvicorn api.main:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=5
Environment=PYTHONPATH=/home/ubuntu/inflow

[Install]
WantedBy=multi-user.target
